# Backend WebSocket URL for chat transport
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat

# Backend API URL for REST endpoints
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# 高德地图 JS API Key (Web端/JS API)
# Get from: https://console.amap.com/dev/key/app
# Select "Web端 (JS API)" when creating the key
NEXT_PUBLIC_AMAP_KEY=your_amap_js_api_key_here
