# Database
DATABASE_URL=postgresql://user:password@localhost:5432/travel_assistant

# DeepSeek API
# Get API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Server
HOST=0.0.0.0
PORT=8000

# Cost Control (per D-18, D-21)
MAX_INPUT_TOKENS=2000
MAX_OUTPUT_TOKENS=2000
REQUEST_TIMEOUT=30

# Context Window (per D-17)
CONTEXT_MESSAGE_LIMIT=20
CONTEXT_TOKEN_LIMIT=4000

# QWeather API (和风天气) - Free tier: 1,000 requests/day
# Get API key from: https://console.qweather.com/#/apps
QWEATHER_API_KEY=your_qweather_api_key_here

# Weather cache TTL in seconds (default: 600 = 10 minutes)
WEATHER_CACHE_TTL=600

# 高德地图 API - Free tier: 2,000-5,000 requests/day for personal developers
# Get API key from: https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here

# Map cache TTL in seconds (default: 900 = 15 minutes)
MAP_CACHE_TTL=900
